# ---------------------------------------------------------------------------
# .gitignore — Cybersecurity Vuln MCP
# ---------------------------------------------------------------------------

# ---- OS / IDE ----
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ---- Secrets & Environment ----
.env
.env.local
.env.*.local
.env.production
.env.development
*.pem
*.key
*.pfx
*.p12
secrets/

# ---- Node.js / TypeScript ----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
build/
*.tsbuildinfo

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ---- Virtual Environments ----
hermes_env/
venv/
env/
ENV/
.venv/

# ---- Docker / Infra ----
*.tar
*.img

# ---- Outputs & Artifacts ----
rapports_generes/
coverage/
*.log

# ---- Editor / AI Assistant traces ----
.claude/
.cursor/

# ---- Large data files ----
trajectory_samples.jsonl
*.db
*.sqlite
*.sqlite3

# ---- Apify / Actor local cache ----
storage/
apify_storage/

# ---- Lock files (optional: keep package-lock.json for reproducibility) ----
# Uncomment next line if you prefer to omit lock files in CI-only repos
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ---- Legacy / duplicate files ----
/readme.txt
/workflow_diagram.png
